@echo off
REM ?????????????????????????????????????????????????????????????????????????????
REM MUIOGO Development Environment Uninstall (Windows)
REM
REM Usage:
REM   scripts\uninstall.bat                 &  full uninstall
REM   scripts\uninstall.bat --uninstall-solvers &  remove system solvers (choco)
REM   scripts\uninstall.bat --yes           &  skip confirmation
REM ?????????????????????????????????????????????????????????????????????????????
setlocal enabledelayedexpansion

set "SCRIPT_DIR=%~dp0"
set "PROJECT_ROOT=%SCRIPT_DIR%.."

if not "%CONDA_DEFAULT_ENV%"=="" (
    echo ERROR: Conda environment "%CONDA_DEFAULT_ENV%" is active.
    echo Run conda deactivate until no conda env is active, then try again.
    exit /b 1
)

where python3.11 >nul 2>&1
if %errorlevel% equ 0 (
    set "PYTHON=python3.11"
    goto :run
)

where py >nul 2>&1
if %errorlevel% equ 0 (
    py -3.11 -c "import sys" >nul 2>&1
    if %errorlevel% equ 0 (
        set "PYTHON=py -3.11"
        goto :run
    )
)

where python >nul 2>&1
if %errorlevel% equ 0 (
    set "PYTHON=python"
    goto :run
)

echo ERROR: Python was not found in PATH to run the uninstaller.
exit /b 1

:run
!PYTHON! "%SCRIPT_DIR%uninstall_dev.py" %*
