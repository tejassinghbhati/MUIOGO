# ============================================================
# MUIOGO Environment Variables — copy this file to .env
# and fill in your own values before running the application.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Flask
# ----------------------------------------------------------

# Secret key used to sign session cookies.
# Change this to a long, random string before deploying.
SECRET_KEY=change-me-to-a-long-random-string

# Port the Flask/Waitress server listens on (default: 5002).
PORT=5002

# ----------------------------------------------------------
# Deployment target
# ----------------------------------------------------------

# Set to 0 for local development, 1 for Heroku deployment.
# Controls CORS origin and host/port binding in app.py.
HEROKU_DEPLOY=0

# ----------------------------------------------------------
# AWS S3 (optional — only needed if S3 sync is enabled)
# ----------------------------------------------------------

# Set AWS_SYNC=1 in Config.py to enable S3 sync on startup.
S3_BUCKET=
S3_KEY=
S3_SECRET=
